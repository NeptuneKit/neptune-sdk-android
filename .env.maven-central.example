# Maven Central credentials (Central Portal token)
MAVEN_CENTRAL_USERNAME=your-central-portal-token-username
MAVEN_CENTRAL_PASSWORD=your-central-portal-token-password

# Namespace in Central Portal (usually your groupId namespace)
MAVEN_CENTRAL_NAMESPACE=com.neptunekit

# PGP key for artifact signing (ASCII armored private key, keep '\n' escaped in one line)
MAVEN_SIGNING_KEY=-----BEGIN PGP PRIVATE KEY BLOCK-----\n...\n-----END PGP PRIVATE KEY BLOCK-----
MAVEN_SIGNING_PASSWORD=your-signing-password

# Optional
VERSION_NAME=0.1.0
